{
  "name": "loop-pilot-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "looppilot-os": "./dist/main.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
